DATABASE_URL=postgresql://wahlumfragen:wahlumfragen@localhost:5432/wahlumfragen

# Canonical public origin, used for absolute URLs in metadata, canonical tags,
# the sitemap and OpenGraph. Set this to the production domain (no trailing
# slash), e.g. https://wahlumfragen.de. Falls back to http://localhost:3000.
# NEXT_PUBLIC_* because it is read in metadata generated at build time.
NEXT_PUBLIC_SITE_URL=

# On-demand cache revalidation (Phase A). The ingest worker POSTs to the app's
# /api/revalidate after a real ingest so cached pages regenerate immediately.
# Shared secret — set the SAME value on the app and the worker.
REVALIDATE_SECRET=change-me
# Only the worker needs this: the app's revalidate endpoint URL.
# e.g. http://localhost:3000/api/revalidate  (or your server's URL)
REVALIDATE_URL=http://localhost:3000/api/revalidate

# Problem-report notifications (the "Problem melden" dialog). The report is
# always saved to the DB; email is a best-effort notification on top. When SMTP
# is not fully configured, the email step is silently skipped (DB still written).
# REPORT_RECIPIENT_EMAIL is where notifications are sent.
REPORT_RECIPIENT_EMAIL=
SMTP_HOST=
SMTP_PORT=587
# "true" for implicit TLS (port 465); otherwise STARTTLS is used.
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
# Envelope/From address. Defaults to SMTP_USER when unset.
SMTP_FROM=

# Triage of submitted problem reports via GET/PATCH /api/reports. Shared secret
# sent in the `x-reports-secret` header. When unset, the endpoint returns 503
# (triage disabled). Keep this endpoint server-local / behind the edge.
REPORTS_SECRET=

# Cloudflare Turnstile — bot protection for the "Problem melden" form. Create a
# widget in the Cloudflare dashboard (Turnstile) for the site's hostname.
# When TURNSTILE_SECRET is unset, verification is skipped (dev/preview) and the
# widget is not rendered; set both in production to enforce the bot gate.
# NEXT_PUBLIC_* because the site key is used in the browser to render the widget.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# countless — our own cookieless, self-hosted analytics. Optional: when either
# is unset, no analytics script is loaded (e.g. in dev/preview). NEXT_PUBLIC_*
# because the beacon runs in the browser.
# The site id registered in the countless instance (its sites.id), e.g.
# wahlumfragen.de
NEXT_PUBLIC_COUNTLESS_SITE=
# The beacon URL of the countless instance, e.g. https://stats.example/script.js
NEXT_PUBLIC_COUNTLESS_SRC=
