{
  "ci": {
    "collect": {
      "startServerCommand": "npm run start",
      "startServerReadyPattern": "Ready in|started server|Local:",
      "startServerReadyTimeout": 60000,
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/trend",
        "http://localhost:3000/koalition",
        "http://localhost:3000/vergleich"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "//": "Budgets start as warn (visible in the PR + uploaded report, but non-blocking) so an unverified threshold can't surprise-fail main. Promote seo/accessibility to \"error\" once the real CI scores are known to clear 0.9.",
      "assertions": {
        "categories:seo": ["warn", { "minScore": 0.9 }],
        "categories:accessibility": ["warn", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:performance": ["warn", { "minScore": 0.8 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
